<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox spacing="10" style="-fx-padding: 20; -fx-background-color: #f5f5f5;" minWidth="900.0" minHeight="600.0"
      xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.baddary.mysales.controller.ProductController">

    <!-- Left side: Form -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <children>
            <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Manage Products"/>

            <GridPane hgap="10.0" vgap="10">
                <padding>
                    <Insets bottom="10" left="10" right="10" top="10"/>
                </padding>
                <Label text="Search by Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="tfSearchByName" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>

                <Label text="ID:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="tfProductId" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1" HBox.hgrow="ALWAYS"/>

                <!-- Product Basic Information -->
                <Label style="-fx-font-weight: bold;" text="Product Name:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="tfProductName" GridPane.columnIndex="1" GridPane.rowIndex="2" HBox.hgrow="ALWAYS"/>

                <Label style="-fx-font-weight: bold;" text="Greatest Unit:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="tfGreatestUnit" GridPane.columnIndex="1" GridPane.rowIndex="3" HBox.hgrow="ALWAYS"/>

                <Label style="-fx-font-weight: bold;" text="Medium Unit:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextField fx:id="tfMediumUnit" GridPane.columnIndex="1" GridPane.rowIndex="4" HBox.hgrow="ALWAYS"/>
                <Label style="-fx-font-weight: bold;" text="Amount:" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                <TextField fx:id="tfMUAmount" GridPane.columnIndex="3" GridPane.rowIndex="4" HBox.hgrow="ALWAYS"/>

                <Label style="-fx-font-weight: bold;" text="Smallest Unit:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextField fx:id="tfSmallestUnit" GridPane.columnIndex="1" GridPane.rowIndex="5" HBox.hgrow="ALWAYS"/>
                <Label style="-fx-font-weight: bold;" text="Amount:" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
                <TextField fx:id="tfSUAmount" GridPane.columnIndex="3" GridPane.rowIndex="5" HBox.hgrow="ALWAYS"/>

                <columnConstraints>
                    <ColumnConstraints/>
                    <ColumnConstraints/>
                    <ColumnConstraints/>
                    <ColumnConstraints/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                </rowConstraints>
            </GridPane>

            <!-- Product Barcode Section -->
            <Text style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Product Barcodes"/>

            <TableView fx:id="tblBarcode" prefHeight="150" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colBarcode" prefWidth="150" text="Barcode">
                        <cellValueFactory>
                            <PropertyValueFactory property="number"/>
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>

            <!-- Barcode Controls -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="tfBarcode" promptText="Enter barcode" HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleAddBarcode" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                        text="Add Barcode"/>
                <Button onAction="#handleRemoveBarcode" style="-fx-background-color: #f44336; -fx-text-fill: white;"
                        text="Remove Barcode"/>
            </HBox>

            <!-- Action Buttons -->
            <HBox alignment="CENTER" spacing="10">
                <Button onAction="#handleNewProduct" prefHeight="33.0" prefWidth="109.0"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="New Product">
                    <HBox.margin>
                        <Insets top="10.0"/>
                    </HBox.margin>
                </Button>
                <Button fx:id="btnAdd" onAction="#handleAddProduct"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Add">
                    <HBox.margin>
                        <Insets top="10.0"/>
                    </HBox.margin>
                </Button>
                <Button fx:id="btnUpdate" onAction="#handleUpdateProduct"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Update">
                    <HBox.margin>
                        <Insets top="10.0"/>
                    </HBox.margin>
                </Button>
            </HBox>

            <!-- Status Message -->
            <Label fx:id="lblStatus" style="-fx-text-fill: #d32f2f; -fx-font-weight: bold;"/>
        </children>
    </VBox>

    <!-- Right side: Product Table -->
    <TableView fx:id="tblProduct" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" prefWidth="300">
        <columns>
            <TableColumn fx:id="colProductName" text="Name"/>
        </columns>
    </TableView>
</HBox>