<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane minWidth="800.0" minHeight="500.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baddary.mysales.controller.CustomerBalanceController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <!-- Top: Search & filter -->
    <top>
        <VBox spacing="10.0">
            <Text style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Customer Balances" />

            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <Label style="-fx-font-weight: bold;" text="Search:" />
                <TextField fx:id="tfSearch" promptText="Customer name..." HBox.hgrow="ALWAYS" />

                <Label style="-fx-font-weight: bold;" text="Filter:" />
                <ComboBox fx:id="cbFilter" prefWidth="120" />   <!-- Items will be set in controller -->

                <Button fx:id="btnSearch" onAction="#handleSearch" text="Search" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
                <Button fx:id="btnReset" onAction="#handleReset" text="Reset" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" />
            </HBox>
        </VBox>
    </top>

    <!-- Center: Table of customers -->
    <center>
        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <TableView fx:id="tblCustomers" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="80">
                        <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colName" text="Name" prefWidth="200">
                        <cellValueFactory><PropertyValueFactory property="name" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colBalance" text="Balance" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="balance" /></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="status" /></cellValueFactory>
                    </TableColumn>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <!-- Action buttons -->
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                <Button fx:id="btnSettle" onAction="#handleSettle" text="Settle Selected" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
                <Button fx:id="btnRefresh" onAction="#handleRefresh" text="Refresh" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
            </HBox>
        </VBox>
    </center>

    <!-- Bottom: Status -->
    <bottom>
        <Label fx:id="lblStatus" style="-fx-text-fill: #d32f2f; -fx-font-weight: bold;" />
    </bottom>
</BorderPane>