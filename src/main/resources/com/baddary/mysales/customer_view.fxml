<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox spacing="10" style="-fx-padding: 20; -fx-background-color: #f5f5f5;" minWidth="900.0" minHeight="600.0"
      xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.baddary.mysales.controller.CustomerController">

    <!-- Left side: Form -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <children>
            <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Manage Customers"/>

            <GridPane hgap="10.0" vgap="10">
                <padding>
                    <Insets bottom="10" left="10" right="10" top="10"/>
                </padding>
                <Label text="Search by Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="tfSearchByName" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>

                <Label text="ID:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="tfCustomerId" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1" HBox.hgrow="ALWAYS"/>

                <!-- Customer Basic Information -->
                <Label style="-fx-font-weight: bold;" text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="tfName" GridPane.columnIndex="1" GridPane.rowIndex="2" HBox.hgrow="ALWAYS"/>

                <Label style="-fx-font-weight: bold;" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="tfEmail" GridPane.columnIndex="1" GridPane.rowIndex="3" HBox.hgrow="ALWAYS"/>

                <Label style="-fx-font-weight: bold;" text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextArea fx:id="taAddress" prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="4" maxWidth="Infinity"/>

                <columnConstraints>
                    <ColumnConstraints/>
                    <ColumnConstraints/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                </rowConstraints>
            </GridPane>

            <!-- Phone Numbers Section -->
            <Text style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Phone Numbers"/>

            <TableView fx:id="tblPhone" prefHeight="150" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colPhoneNumber" prefWidth="150" text="Number">
                        <cellValueFactory>
                            <PropertyValueFactory property="number"/>
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>

            <!-- Phone Number Controls -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="tfPhoneNumber" promptText="Enter phone number" HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleAddPhone" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                        text="Add Phone"/>
                <Button onAction="#handleRemovePhone" style="-fx-background-color: #f44336; -fx-text-fill: white;"
                        text="Remove Phone"/>
            </HBox>

            <!-- Action Buttons -->
            <HBox alignment="CENTER" spacing="10">
                <Button onAction="#handleNewCustomer" prefHeight="33.0" prefWidth="109.0"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="New Customer">
                    <HBox.margin>
                        <Insets top="10.0"/>
                    </HBox.margin>
                </Button>
                <Button fx:id="btnAdd" onAction="#handleAddCustomer"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Add">
                    <HBox.margin>
                        <Insets top="10.0"/>
                    </HBox.margin>
                </Button>
                <Button fx:id="btnUpdate" onAction="#handleUpdateCustomer"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Update">
                    <HBox.margin>
                        <Insets top="10.0"/>
                    </HBox.margin>
                </Button>
            </HBox>

            <!-- Status Message -->
            <Label fx:id="lblStatus" style="-fx-text-fill: #d32f2f; -fx-font-weight: bold;"/>
        </children>
    </VBox>

    <!-- Right side: Customer Table -->
    <TableView fx:id="tblCustomer" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" prefWidth="300">
        <columns>
            <TableColumn fx:id="colCustomerName" text="Name"/>
        </columns>
    </TableView>
</HBox>